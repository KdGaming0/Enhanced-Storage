{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "A unified overlay for Hypixel SkyBlock storage — all your Ender Chests and Backpacks in one searchable view.",
  "authors": [
    "Kd_Gaming1"
  ],
  "contact": {
    "homepage": "https://modrinth.com/project/ICyROmSc",
    "sources": "https://github.com/kdgaming0/Enhanced-Storage"
  },
  "license": "GPL-3.0-only",
  "icon": "assets/enhanced_storage/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.github.kdgaming0.enhancedstorage.EnhancedStorage"
    ]
  },
  "mixins": [
    "enhancedstorage.mixins.json"
  ],
  "accessWidener": "enhancedstorage.ct",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft}",
    "fabric-api": "*",
    "midnightlib": ">=1.9.3"
  }
